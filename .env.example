ODSSWS_ENVIRONMENT=development
ODSSWS_DATABASE_URL=postgresql+psycopg://odssws:odssws@localhost:5432/odssws
ODSSWS_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]
# Server-side API origin used by the Next.js app and /api/proxy/* route.
# In Vercel, set this to your deployed API base URL.
ODSSWS_API_BASE_URL=http://localhost:8000
# Optional legacy/public fallback. The browser no longer needs a direct API origin.
NEXT_PUBLIC_API_BASE_URL=
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
ODSSWS_API_KEY=change-me-before-deploying
ODSSWS_AUTH_TOKEN_SECRET=
ODSSWS_AUTH_ISSUER=odssws
ODSSWS_AUTH_AUDIENCE=odssws-operators
ODSSWS_ALLOW_LEGACY_API_KEY=false

# Real label feed for bootstrap_real_data_flow
# Modes: disabled | dhis2_csv_url | dhis2_csv_file | standard_csv
ODSSWS_REAL_LABELS_MODE=disabled
ODSSWS_REAL_LABELS_SOURCE=dghs_dhis2_weekly_cases
ODSSWS_REAL_LABEL_CASE_THRESHOLD=1
ODSSWS_DHIS2_LABEL_EXPORT_URL=
ODSSWS_DHIS2_LABEL_EXPORT_PATH=
ODSSWS_DHIS2_USERNAME=
ODSSWS_DHIS2_PASSWORD=
